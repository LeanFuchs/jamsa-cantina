---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactContent from '../components/ContactContent.astro';
import es from '../locales/es.js';
import { interpolate } from '../lib/content';
const t = es;
const currentLang = 'es';
---

<BaseLayout
  title={interpolate(es.meta.contactTitle, es)}
  description={interpolate(es.meta.contactDescription, es)}
  t={t} 
  currentLang={currentLang}
>
  <ContactContent t={es} />
</BaseLayout>