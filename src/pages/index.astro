---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import LocationCard from '../components/LocationCard.astro';
import Gallery from '../components/Gallery.astro';
import Reviews from '../components/Reviews.astro';
import { interpolate, t } from '../lib/content';
---

<BaseLayout>
  <Hero />
  <LocationCard />
  <Gallery limit={6} />
  <Reviews />

  <section class="bg-base-100">
    <div class="section-shell grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="eyebrow">{t.home.aboutEyebrow}</p>
        <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">{interpolate(t.home.aboutHeading)}</h2>
      </div>
      <div class="space-y-5 text-lg leading-8">
        {t.home.aboutParagraphs.map((paragraph) => <p>{interpolate(paragraph)}</p>)}
      </div>
    </div>
  </section>
</BaseLayout>
