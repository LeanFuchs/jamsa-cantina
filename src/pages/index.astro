---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeContent from '../components/HomeContent.astro';
import es from '../locales/es.js';
import { interpolate } from '../lib/content';
const t = es;
const currentLang = 'es';
---

<BaseLayout
  title={interpolate(es.meta.homeTitle, es)}
  description={interpolate(es.meta.homeDescription, es)}
  t={t} 
  currentLang={currentLang}
>
  <HomeContent t={es} />
</BaseLayout>
