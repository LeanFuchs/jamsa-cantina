---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutContent from '../components/AboutContent.astro';
import es from '../locales/es.js';
import { interpolate } from '../lib/content';
const t = es;
const currentLang = 'es';
---

<BaseLayout
  title={interpolate(es.meta.aboutTitle, es)}
  description={interpolate(es.meta.aboutDescription, es)}
  t={t} 
  currentLang={currentLang}
>
  <AboutContent t={es} />
</BaseLayout>