---
import BaseLayout from '../layouts/BaseLayout.astro';
import { interpolate, siteInfo as info, t } from '../lib/content';
---

<BaseLayout
  title={interpolate(t.meta.aboutTitle)}
  description={interpolate(t.meta.aboutDescription)}
>
  <section class="bg-[#f4eadb]">
    <div class="section-shell">
      <p class="eyebrow">{t.about.eyebrow}</p>
      <h1 class="mt-3 max-w-3xl font-serif text-5xl font-bold leading-tight text-neutral">{t.about.heading}</h1>
    </div>
  </section>

  <section class="bg-base-100">
    <div class="section-shell grid gap-10 lg:grid-cols-[1fr_0.8fr]">
      <div class="space-y-6 text-lg leading-8">
        {t.about.paragraphs.map((paragraph) => <p>{interpolate(paragraph)}</p>)}
      </div>
      <aside class="rounded-lg border border-base-300 bg-base-200 p-6">
        <h2 class="text-xl font-bold text-neutral">{t.labels.quickFacts}</h2>
        <dl class="mt-5 space-y-4">
          <div>
            <dt class="text-sm font-semibold uppercase text-secondary">{t.labels.cuisine}</dt>
            <dd>{t.business.servesCuisine}</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase text-secondary">{t.labels.neighborhood}</dt>
            <dd>{t.business.neighborhood}</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase text-secondary">{t.labels.atmosphere}</dt>
            <dd>{t.business.atmosphere}</dd>
          </div>
        </dl>
        <a class="btn btn-primary mt-6" href={info.mapUrl} target="_blank" rel="noreferrer">{t.cta.directions}</a>
      </aside>
    </div>
  </section>
</BaseLayout>
