---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryContent from '../components/GalleryContent.astro';
import es from '../locales/es.js';
import { interpolate } from '../lib/content';
const t = es;
const currentLang = 'es';
---

<BaseLayout
  title={interpolate(es.meta.galleryTitle, es)}
  description={interpolate(es.meta.galleryDescription, es)}
  t={t} 
  currentLang={currentLang}
>
  <GalleryContent t={es} />
</BaseLayout>