---
import { siteInfo as info, t } from '../lib/content';

const openingHoursSpecification = info.hours
  .filter((hour) => !hour.closed)
  .flatMap((hour) =>
    hour.intervals.map((interval) => ({
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: hour.dayKey.charAt(0).toUpperCase() + hour.dayKey.slice(1),
      opens: interval.opens,
      closes: interval.closes
    }))
  );

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: t.business.name,
  image: new URL(info.images.hero, info.website).toString(),  url: info.website,
  telephone: info.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: info.address.street,
    addressLocality: info.address.city,
    addressRegion: info.address.region,
    postalCode: info.address.postalCode,
    addressCountry: info.address.country
  },
  openingHoursSpecification,
  servesCuisine: t.business.servesCuisine,
  menu: info.menuUrl,
  sameAs: [info.instagramUrl]
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
