---
import { siteInfo as info } from '../lib/content';
const { t, currentLang = 'es', canonicalUrl = info.website, ogImageUrl = '' } = Astro.props;

const hoursData = Array.isArray(info?.hours) ? info.hours : [];

const dayMap = {
  monday: 'Monday',
  tuesday: 'Tuesday',
  wednesday: 'Wednesday',
  thursday: 'Thursday',
  friday: 'Friday',
  saturday: 'Saturday',
  sunday: 'Sunday'
};

const openingHoursSpecification = Array.isArray(hoursData) 
  ? hoursData
      .filter((hour) => hour && !hour.closed && hour.intervals)
      .flatMap((hour) =>
        hour.intervals.map((interval) => ({
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: `https://schema.org/${dayMap[hour.dayKey] || hour.dayKey}`,
          opens: interval.opens,
          closes: interval.closes
        }))
      )
  : [];

const restaurantId = `${info.website}/#restaurant`;
const websiteId = `${info.website}/#website`;
const primaryImage = ogImageUrl || (info.images?.hero ? new URL(info.images.hero, info.website).toString() : '');

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': websiteId,
      name: t.business?.name || 'Jamsa Cantina',
      url: info.website,
      inLanguage: currentLang === 'es' ? 'es-AR' : 'en'
    },
    {
      '@type': 'Restaurant',
      '@id': restaurantId,
      name: t.business?.name || 'Jamsa Cantina',
      description: t.business?.description || '',
      image: primaryImage,
      url: canonicalUrl,
      telephone: info.phoneE164 || info.phoneDisplay || '',
      priceRange: '$$',
      acceptsReservations: true,
      address: {
        '@type': 'PostalAddress',
        streetAddress: info.address?.street || '',
        addressLocality: info.address?.locality || 'Palermo',
        addressRegion: info.address?.region || 'CABA',
        addressCountry: info.address?.country || 'AR'
      },
      geo: info.geo ? {
        '@type': 'GeoCoordinates',
        latitude: info.geo.latitude,
        longitude: info.geo.longitude
      } : undefined,
      openingHoursSpecification,
      servesCuisine: t.business?.servesCuisine || '',
      hasMenu: info.menuUrl || '',
      sameAs: info.instagramUrl ? [info.instagramUrl] : []
    }
  ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
