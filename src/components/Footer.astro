---
// src/components/Footer.astro
import { formatAddress, siteInfo as info} from '../lib/content';
import whatsappUrl from '../utils/get-whatsapp-url'

// Recibimos t y además currentLang ('es' o 'en') desde el BaseLayout
const { t, currentLang = 'es' } = Astro.props;

const fullAddress = formatAddress(t); // Le pasamos t para internacionalizar la dirección

// Definimos los enlaces de navegación según el idioma en el que está parado el usuario
const navLinks = currentLang === 'en' 
  ? [
      { href: '/en', label: t.nav.home },
      { href: '/en/about', label: t.nav.about },
      { href: '/en/gallery', label: t.nav.gallery },
      { href: '/en/contact', label: t.nav.contact }
    ]
  : [
      { href: '/', label: t.nav.home },
      { href: '/sobre-nosotros', label: t.nav.about },
      { href: '/galeria', label: t.nav.gallery },
      { href: '/contacto', label: t.nav.contact }
    ];
---

<footer class="border-t border-base-300 bg-neutral text-neutral-content">
  <div class="section-shell grid gap-8 py-10 md:grid-cols-[1.2fr_1fr_1fr_1fr]">
    
    <div>
      <p class="text-xl font-bold">{t.business.name}</p>
      <p class="mt-3 max-w-md text-sm opacity-80">{t.footer.description}</p>
    </div>

    <div>
      <p class="font-semibold">{t.footer.navigation}</p>
      <nav class="mt-3 flex flex-col gap-2">
        {navLinks.map((link) => (
          <a class="text-sm opacity-80 hover:opacity-100" href={link.href}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <address class="not-italic">
      <p class="font-semibold">{t.labels.visit}</p>
      <a class="mt-3 block text-sm opacity-80 hover:opacity-100" href={info.mapUrl} target="_blank" rel="noreferrer">
        {fullAddress}
      </a>
      <a class="mt-2 block text-sm opacity-80 hover:opacity-100" href={whatsappUrl} target="_blank">
        {t.cta.reservationWhatsapp}
      </a>
    </address>

    <div>
      <p class="font-semibold">{t.labels.links}</p>
      <a class="mt-3 block text-sm opacity-80 hover:opacity-100" href={info.menuUrl} target="_blank" rel="noreferrer">
        {t.cta.menu}
      </a>
      <a class="mt-2 block text-sm opacity-80 hover:opacity-100" href={info.instagramUrl} target="_blank" rel="noreferrer">
        {t.cta.instagram}
      </a>
    </div>
  </div>
</footer>
