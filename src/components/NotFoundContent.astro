---
import BaseLayout from '../layouts/BaseLayout.astro';
const { t } = Astro.props;
---

  <section class="relative bg-primary min-h-[70vh] flex items-center py-20 overflow-hidden">
    <!-- Grid sutil adaptado para fondo oscuro (opacidad 0.03 con líneas blancas) -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    
    <div class="section-shell relative max-w-4xl mx-auto flex flex-col items-center text-center px-4 w-full">
      <!-- Número 404 Gigante con estética Serif elegante -->
      <h1 class="font-serif text-8xl sm:text-9xl md:text-[12rem] font-bold tracking-tight text-[#f4eadb] leading-none drop-shadow-sm select-none">
        404
      </h1>
      
      <!-- Descripción localizada -->
      <p class="mt-6 text-base sm:text-lg md:text-xl text-[#f4eadb]/90 max-w-md mx-auto font-sans balance">
        {t.errors?.notFound}
      </p>
      
      <!-- Botón de retorno al Home -->
      <div class="mt-10 w-full sm:w-auto">
        <a 
          class="btn btn-md px-8 bg-[#f4eadb] text-[#005a66] border-none hover:bg-[#eaddc9] shadow-lg w-full sm:w-auto min-w-[200px] font-bold" 
          href="/"
        >
          {t.nav.home}
        </a>
      </div>
    </div>
  </section>

<style>
  /* Evita cortes feos de texto largo en pantallas chicas */
  .balance {
    text-wrap: balance;
  }
</style>