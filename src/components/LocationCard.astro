---
import { formatAddress, siteInfo as info, t } from '../lib/content';

const fullAddress = formatAddress();
// Strip the plus sign to make a valid WhatsApp API link
const whatsappUrl = `https://wa.me/${info.phone.replace('+', '')}`;
---

<section class="bg-[#f4eadb] py-12 md:py-20" id="visit">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 grid gap-8 lg:grid-cols-[1fr_1.1fr] items-start">
    
    <div class="rounded-2xl border border-neutral/10 bg-base-100 p-6 shadow-xl sm:p-10">
      <p class="eyebrow uppercase tracking-wider text-xs font-semibold text-primary/80">{t.location.eyebrow}</p>
      <h2 class="mt-2 font-serif text-3xl sm:text-4xl font-bold text-neutral leading-tight">{t.location.heading}</h2>
      
      <div class="mt-8 space-y-6">
        <!-- Address Block -->
        <div class="flex gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#005a66]/10 text-[#005a66]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-neutral tracking-wide text-sm uppercase">{t.labels.address}</h3>
            <a class="link link-hover text-neutral/80 mt-1 block hover:text-primary transition-colors duration-200" href={info.mapUrl} target="_blank" rel="noreferrer">
              {fullAddress}
            </a>
          </div>
        </div>

        <hr class="border-base-200" />

        <!-- WhatsApp Block with your exact SVG choice -->
        <div class="flex gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#005a66]/10 text-[#005a66]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5" viewBox="0 0 16 16">
              <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-neutral tracking-wide text-sm uppercase">Reservas</h3>
            <a class="link link-hover text-neutral/80 mt-1 block hover:text-primary transition-colors duration-200" href={whatsappUrl} target="_blank" rel="noreferrer">
              {info.phoneDisplay}
            </a>
          </div>
        </div>

        <hr class="border-base-200" />

        <!-- Hours Block -->
        <div class="flex gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#005a66]/10 text-[#005a66]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <div class="w-full">
            <h3 class="font-bold text-neutral tracking-wide text-sm uppercase mb-3">{t.labels.hours}</h3>
            <dl class="divide-y divide-base-200 bg-base-200/30 rounded-xl p-4 text-sm">
              {info.hours.map((hour) => (
                <div class="grid grid-cols-[7rem_1fr] gap-4 py-2 first:pt-0 last:pb-0">
                  <dt class="font-semibold text-neutral">{t.days[hour.dayKey]}</dt>
                  <dd class="text-neutral/80 text-right sm:text-left">
                    {hour.closed ? (
                      <span class="text-error/70 font-medium italic">{t.labels.closed}</span>
                    ) : (
                      hour.display
                    )}
                  </dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </div>
    
    <div class="h-full min-h-[28rem] lg:min-h-full overflow-hidden rounded-2xl border border-neutral/10 bg-base-100 shadow-xl lg:self-stretch">
      <iframe
        title={`${t.business.name} map`}
        src={info.mapEmbedUrl}
        class="h-full min-h-[28rem] w-full border-0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

  </div>
</section>
