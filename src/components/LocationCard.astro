---
// src/components/LocationCard.astro
import { formatAddress, siteInfo as info } from '../lib/content';
import whatsappUrl from '../utils/get-whatsapp-url'

// 1. Recibimos el diccionario dinámico por props
const { t } = Astro.props;

// 2. Le pasamos 't' al helper para que la dirección se renderice según el idioma activo
const fullAddress = formatAddress(t);

// 3. Escudo defensivo para evitar el error 'undefined (reading map)' si reestructurás content.js
const hoursData = info.hours || t.business?.hours || [];
const safeHours = Array.isArray(hoursData) ? hoursData : [];
---

<section class="bg-base-200/40 py-16 md:py-24" id="visit">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-2xl mb-12">
      <p class="text-xs font-bold uppercase tracking-wider text-primary/90">{t.location.eyebrow}</p>
      <h2 class="mt-2 font-serif text-3xl sm:text-4xl font-extrabold text-neutral tracking-tight leading-tight">
        {t.location.heading}
      </h2>
    </div>

    <div class="grid gap-8 lg:grid-cols-12 items-stretch">
      
      <div class="lg:col-span-7 flex flex-col gap-6">
        
        <div class="rounded-2xl border border-base-200 bg-base-100 p-6 shadow-sm sm:p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <h3 class="font-bold text-neutral text-sm uppercase tracking-wider">{t.labels.hours}</h3>
          </div>
          
          <ul class="space-y-4 text-sm">
            {safeHours.map((hour) => (
              <li class="grid grid-cols-1 sm:grid-cols-[5rem_1fr_auto] items-baseline gap-x-4 border-b border-base-100 pb-2 last:border-0 last:pb-0">
                <span class="font-bold text-neutral">{t.days?.[hour.dayKey] || hour.dayKey}</span>
                <span class="hidden sm:inline border-b border-dotted border-base-300 mb-1 opacity-60"></span>
                <span class="text-neutral/80 font-mono text-xs sm:text-sm sm:text-right">
                  {hour.closed ? (
                    <span class="text-error bg-error/5 px-2 py-0.5 rounded font-sans font-semibold text-xs">{t.labels.closed}</span>
                  ) : (
                    hour.display
                  )}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-2xl border border-base-200 bg-base-100 p-6 shadow-sm sm:p-8 grid gap-6 sm:grid-cols-2 items-start">
          <div class="space-y-6">
            <div class="flex items-start gap-3.5">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4.5 h-4.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-neutral text-xs uppercase tracking-wider">{t.labels.address}</h3>
                <p class="text-sm text-neutral/70 mt-1 leading-relaxed">{fullAddress}</p>
              </div>
            </div>

            <div class="flex items-start gap-3.5">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-success/10 text-success">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4.5 h-4.5" viewBox="0 0 16 16">
                  <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-neutral text-xs uppercase tracking-wider">{t.footer.reservation}</h3>
                <p class="text-sm text-neutral/70 mt-1">{info.phoneDisplay}</p>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-2 justify-center h-full sm:border-l sm:border-base-200 sm:pl-6">
            <a class="btn btn-primary btn-sm h-11 font-semibold w-full" href={info.mapUrl} target="_blank" rel="noreferrer">
              {t.cta.directions}
            </a>
            <a class="btn btn-ghost border-base-300 btn-sm h-11 font-medium w-full" href={whatsappUrl} target="_blank" rel="noreferrer">
              {t.cta.reservationWhatsapp}
            </a>
          </div>
        </div>

      </div>
      
      <div class="lg:col-span-5 min-h-[24rem] lg:min-h-full overflow-hidden rounded-2xl border border-base-200 bg-base-100 shadow-sm">
        <iframe
          title={`${t.business.name} map`}
          src={info.mapEmbedUrl}
          class="h-full w-full min-h-[24rem] border-0 opacity-95 hover:opacity-100 transition-opacity duration-200"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

    </div>
  </div>
</section>
