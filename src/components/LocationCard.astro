---
import { formatAddress, siteInfo as info, t } from '../lib/content';

const fullAddress = formatAddress();
---

<section class="bg-base-200" id="visit">
  <div class="section-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <p class="eyebrow">{t.location.eyebrow}</p>
      <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">{t.location.heading}</h2>
      <div class="mt-8 space-y-5">
        <address class="not-italic">
          <p class="font-semibold text-neutral">{t.labels.address}</p>
          <a class="link link-hover mt-1 block" href={info.mapUrl} target="_blank" rel="noreferrer">{fullAddress}</a>
        </address>
        <div>
          <p class="font-semibold text-neutral">{t.labels.phone}</p>
          <a class="link link-hover mt-1 block" href={`tel:${info.phone}`}>{info.phoneDisplay}</a>
        </div>
        <div>
          <p class="font-semibold text-neutral">{t.labels.hours}</p>
          <dl class="mt-3 grid gap-2">
            {info.hours.map((hour) => (
              <div class="grid grid-cols-[7rem_1fr] gap-4 text-sm">
                <dt class="font-medium">{t.days[hour.dayKey]}</dt>
                <dd>{hour.display}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
    <div class="overflow-hidden rounded-lg border border-base-300 bg-base-100 shadow-sm">
      <iframe
        title={`${t.business.name} map`}
        src={info.mapEmbedUrl}
        class="h-[28rem] w-full"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
