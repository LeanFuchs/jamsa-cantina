---
import { Image } from 'astro:assets';
import { siteInfo as info, t } from '../lib/content';
---

<section class="relative min-h-[calc(100vh-4rem)] overflow-hidden">
  <Image
    class="absolute inset-0 h-full w-full object-cover"
    src={info.images.hero}
    alt={t.images.heroAlt}
    width={1800}
    height={1200}
    loading="eager"
  />
  <div class="absolute inset-0 bg-neutral/55"></div>
  <div class="relative mx-auto flex min-h-[calc(100vh-4rem)] max-w-6xl items-center px-4 py-20 sm:px-6 lg:px-8">
    <div class="max-w-2xl text-base-100">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-accent">{t.business.neighborhood}</p>
      <h1 class="font-serif text-5xl font-bold leading-tight sm:text-6xl lg:text-7xl">{t.business.name}</h1>
      <p class="mt-5 max-w-xl text-lg leading-8 text-base-100/90 sm:text-xl">{t.business.tagline}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary btn-lg" href={info.mapUrl} target="_blank" rel="noreferrer">{t.cta.directions}</a>
        <a class="btn btn-outline btn-lg border-base-100 text-base-100 hover:border-base-100 hover:bg-base-100 hover:text-neutral" href={info.menuUrl} target="_blank" rel="noreferrer">{t.cta.menu}</a>
      </div>
      <a class="mt-5 inline-flex text-sm font-semibold text-base-100 underline decoration-accent decoration-2 underline-offset-4 hover:text-accent" href={info.instagramUrl} target="_blank" rel="noreferrer">{t.cta.followInstagram}</a>
    </div>
  </div>
</section>
