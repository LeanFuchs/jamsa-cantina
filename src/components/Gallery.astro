---
import { Image } from 'astro:assets';
import { siteInfo as info, t } from '../lib/content';

const { limit } = Astro.props;
const imageDimensions = {
  '/images/hummus.webp': { width: 1456, height: 1600 },
  '/images/pollo.webp': { width: 1357, height: 1600 },
  '/images/shakshuka.webp': { width: 1482, height: 1600 },
  '/images/lehmeyun.webp': { width: 1543, height: 1600 },
  '/images/pimientos.webp': { width: 1580, height: 1600 },
  '/images/peras.webp': { width: 1595, height: 1600 }
};
const images = info.images.gallery.map((src, index) => ({
  src,
  alt: t.images.galleryAlt[index],
  ...imageDimensions[src]
}));
const visibleImages = limit ? images.slice(0, limit) : images;
---

<section class="bg-base-100">
  <div class="section-shell">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">{t.gallery.eyebrow}</p>
        <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">{t.gallery.heading}</h2>
      </div>
      <a class="btn btn-secondary" href={info.instagramUrl} target="_blank" rel="noreferrer">{t.cta.instagram}</a>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {visibleImages.map((image) => (
        <figure class="overflow-hidden rounded-lg bg-base-200">
          <Image
            class="aspect-[4/3] h-full w-full object-cover transition duration-300 hover:scale-105"
            src={image.src}
            alt={image.alt}
            width={image.width}
            height={image.height}
            widths={[400, 700, 900]}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            loading="lazy"
            format="avif"
            quality={75}
          />
        </figure>
      ))}
    </div>
  </div>
</section>
