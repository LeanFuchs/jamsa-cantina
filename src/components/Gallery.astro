---
import { Image } from 'astro:assets';
import { siteInfo as info, t } from '../lib/content';
import albondigas from '../assets/albondigas-1.webp';
import berenjenas from '../assets/berenjenas.webp';
import fatush from '../assets/fatush.webp';
import hummusVeggie from '../assets/hummus-veggie.webp';
import latkes from '../assets/latkes-1.webp';
import lehmeyun from '../assets/lehmeyun-1.webp';
import lehmeyunEspejo from '../assets/lehmeyun-espejo.webp';
import malabi from '../assets/malabi-1.webp';
import osobuco from '../assets/osobuco-1.webp';
import peras from '../assets/peras-1.webp';
import pimientos from '../assets/pimientos-1.webp';
import platitos1 from '../assets/platitos-1.webp';
import platitos2 from '../assets/platitos-2.webp';
import platitos3 from '../assets/platitos-3.webp';
import platitos4 from '../assets/platitos-4.webp';
import pollo from '../assets/pollo-1.webp';
import tabule from '../assets/tabule-1.webp';

interface Props {
  /** 'preview' = compact mosaic (e.g. homepage teaser). 'full' = masonry gallery. */
  variant?: 'preview' | 'full';
  /** Cap the number of images shown. */
  limit?: number;
}

const { variant = 'full', limit } = Astro.props as Props;

const assetMap = {
  albondigas,
  berenjenas,
  fatush,
  hummusVeggie,
  latkes,
  lehmeyun,
  lehmeyunEspejo,
  malabi,
  osobuco,
  peras,
  pimientos,
  platitos1,
  platitos2,
  platitos3,
  platitos4,
  pollo,
  tabule,
};

const allImages = info.images.gallery.map((key, index) => {
  const src = assetMap[key];
  if (!src) {
    throw new Error(`Gallery image key "${key}" has no matching import in Gallery.astro`);
  }
  return {
    key,
    src,
    alt: t.images.galleryAlt[index],
  };
});

// 1. First layer slice based on parent components parameters (limits to 15 on homepage index)
let images = limit ? allImages.slice(0, limit) : allImages;

// 2. Setup identifying tall items
const TALL_KEYS = new Set(['hummusVeggie', 'latkes', 'lehmeyunEspejo', 'osobuco', 'platitos1', 'platitos3', 'platitos4']);

// 3. Ensure the full variant layout ends perfectly flat without trailing gaps on desktop grids
if (variant === 'full') {
  let totalCellWeight = 0;
  const desktopColumns = 4;
  const balancedImages = [];

  for (const img of images) {
    const weight = TALL_KEYS.has(img.key) ? 2 : 1;
    balancedImages.push(img);
    totalCellWeight += weight;
  }

  // Calculate left over hanging blocks that break a solid grid line boundary
  const remainder = totalCellWeight % desktopColumns;
  if (remainder !== 0) {
    // Trim back trailing items until it fits cleanly inside a clean 4-wide multi-row end row
    let currentWeightCount = totalCellWeight;
    while (currentWeightCount % desktopColumns !== 0 && balancedImages.length > 0) {
      const removedItem = balancedImages.pop();
      currentWeightCount -= TALL_KEYS.has(removedItem.key) ? 2 : 1;
    }
    images = balancedImages;
  }
}

const tieredImages = images.map((image, i) => {
  if (i === 0) return { ...image, tier: 'hero' as const, slotClass: '' };
  if (i <= 4) return { ...image, tier: 'featured' as const, slotClass: `mosaic-slot-${i}` };
  return { ...image, tier: 'minor' as const, slotClass: '' };
});

const gridImages = images.map((image) => ({
  ...image,
  isTall: TALL_KEYS.has(image.key),
}));
---

<section class="bg-base-100">
  <div class="section-shell">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">{t.gallery.eyebrow}</p>
        <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">{t.gallery.heading}</h2>
      </div>
      <a class="btn btn-secondary" href={info.instagramUrl} target="_blank" rel="noreferrer">{t.cta.instagram}</a>
    </div>

    {variant === 'preview' ? (
      <div class="mosaic mt-8">
        {tieredImages.map((image, i) => (
          <figure class={`mosaic-item mosaic-item--${image.tier} ${image.slotClass} overflow-hidden rounded-lg bg-base-200`}>
            <Image
              class="h-full w-full object-cover transition duration-500 hover:scale-105"
              src={image.src}
              alt={image.alt}
              widths={
                image.tier === 'hero'
                  ? [500, 800, 1100, 1600]
                  : image.tier === 'featured'
                    ? [300, 500, 700]
                    : [200, 350, 500]
              }
              sizes={
                image.tier === 'hero'
                  ? "(max-width: 768px) 100vw, 50vw"
                  : image.tier === 'featured'
                    ? "(max-width: 768px) 50vw, 25vw"
                    : "16vw"
              }
              loading={i === 0 ? 'eager' : 'lazy'}
              format="webp"
              quality={80}
            />
          </figure>
        ))}
      </div>
    ) : (
      <div class="photo-grid mt-8">
        {gridImages.map((image) => (
          <figure class={`photo-grid-item ${image.isTall ? 'photo-grid-item--tall' : ''} overflow-hidden rounded-lg bg-base-200`}>
            <Image
              class="h-full w-full object-cover transition duration-500 hover:scale-105"
              src={image.src}
              alt={image.alt}
              widths={[400, 700, 1100, 1600]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
              loading="lazy"
              format="webp"
              quality={80}
            />
          </figure>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .mosaic {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .mosaic-item--hero {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
    aspect-ratio: 1 / 1;
  }

  .mosaic-item--featured {
    aspect-ratio: 1 / 1;
  }

  .mosaic-slot-1 {
    grid-column: 3 / 4;
    grid-row: 1 / 2;
  }
  .mosaic-slot-2 {
    grid-column: 4 / 5;
    grid-row: 1 / 2;
  }
  .mosaic-slot-3 {
    grid-column: 3 / 4;
    grid-row: 2 / 3;
  }
  .mosaic-slot-4 {
    grid-column: 4 / 5;
    grid-row: 2 / 3;
  }

  .mosaic-item--minor {
    grid-column: span 1;
    aspect-ratio: 1 / 1;
  }

  @media (min-width: 1024px) {
    .mosaic {
      grid-template-columns: repeat(6, 1fr);
    }
    .mosaic-item--hero {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }
    .mosaic-slot-1 {
      grid-column: 3 / 4;
      grid-row: 1 / 2;
    }
    .mosaic-slot-2 {
      grid-column: 4 / 5;
      grid-row: 1 / 2;
    }
    .mosaic-slot-3 {
      grid-column: 3 / 4;
      grid-row: 2 / 3;
    }
    .mosaic-slot-4 {
      grid-column: 4 / 5;
      grid-row: 2 / 3;
    }
    .mosaic-item--minor {
      grid-column: span 1;
    }
  }

  @media (max-width: 1023px) {
    .mosaic-item--minor {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .mosaic {
      grid-template-columns: repeat(2, 1fr);
    }
    .mosaic-item--hero {
      grid-column: 1 / 3;
      grid-row: auto;
      aspect-ratio: 16 / 10;
    }
    .mosaic-item--featured {
      grid-column: span 1 !important;
      grid-row: auto !important;
      aspect-ratio: 1 / 1;
    }
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-flow: dense;
    grid-auto-rows: 11rem;
    gap: 0.75rem;
  }

  .photo-grid-item {
    grid-row: span 1;
  }

  .photo-grid-item--tall {
    grid-row: span 2;
  }

  @media (min-width: 640px) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 13rem;
    }
  }

  @media (min-width: 1024px) {
    .photo-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 14rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mosaic-item img,
    .photo-grid-item img {
      transition: none;
    }
  }
</style>
