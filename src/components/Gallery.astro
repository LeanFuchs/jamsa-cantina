---
// src/components/Gallery.astro
import { Image } from 'astro:assets';
import { siteInfo as info } from '../lib/content';

// 1. Recibimos el diccionario dinámico 't' por las props globales
const { t } = Astro.props;

interface Props {
  t: any; // Declaramos t explícitamente si usás TypeScript
  /** 'preview' = compact mosaic (e.g. homepage teaser). 'full' = masonry gallery. */
  variant?: 'preview' | 'full';
  /** Cap the number of images shown. */
  limit?: number;
}

const { variant = 'full', limit } = Astro.props as Props;

// Automatically load all webp images from the assets directory dynamically
const localImages = import.meta.glob<{ default: ImageMetadata }>('../assets/*.webp');

const galleryItems = info.images?.gallery || [];
// Resolve JSON objects/strings safely and match them directly with localized alt definitions
const allImages = info.images.gallery
  .map((item: any) => {
    const id = typeof item === 'object' && item !== null ? item.id : item;

    // Patrón de resolución de archivos
    const fileVariants = [
      `../assets/${id}.webp`,
      `../assets/${id}-1.webp`,
      `../assets/${id.replace(/[A-Z]/g, (m: string) => '-' + m.toLowerCase())}.webp`
    ];

    let src = null;
    for (const path of fileVariants) {
      if (localImages[path]) {
        src = localImages[path];
        break;
      }
    }

    if (!src) return null;

    // --- ACCESO SEGURO A LOS ALT TEXTS ---
    // 1. Intentamos obtener la traducción específica del diccionario 't'
    // 2. Si t.images o galleryAlt no existen, evitamos el crash usando ?.
    // 3. Fallback: generamos un alt legible a partir del ID del plato[cite: 7, 8]
    const altText = t.images?.galleryAlt?.[id] 
                    || `Imagen de ${id.replace(/([A-Z])/g, ' $1')}`;

    return {
      key: id,
      src: src(),
      alt: altText,
    };
  })
  .filter((img): img is NonNullable<typeof img> => img !== null);

// Normal positional slicing configuration parameters 
let images = limit ? allImages.slice(0, limit) : allImages;

const TALL_KEYS = new Set(['hummusVeggie', 'latkes', 'lehmeyunEspejo', 'osobuco', 'platitos1', 'platitos3', 'platitos4']);

if (variant === 'full') {
  let totalCellWeight = 0;
  const desktopColumns = 4;
  const balancedImages = [];

  for (const img of images) {
    const weight = TALL_KEYS.has(img.key) ? 2 : 1;
    balancedImages.push(img);
    totalCellWeight += weight;
  }

  const remainder = totalCellWeight % desktopColumns;
  if (remainder !== 0) {
    let currentWeightCount = totalCellWeight;
    while (currentWeightCount % desktopColumns !== 0 && balancedImages.length > 0) {
      const removedItem = balancedImages.pop();
      if (removedItem) {
        currentWeightCount -= TALL_KEYS.has(removedItem.key) ? 2 : 1;
      }
    }
    images = balancedImages;
  }
}

const tieredImages = images.map((image, i) => {
  if (i === 0) return { ...image, tier: 'hero' as const, slotClass: '' };
  if (i <= 4) return { ...image, tier: 'featured' as const, slotClass: `mosaic-slot-${i}` };
  return { ...image, tier: 'minor' as const, slotClass: '' };
});

const gridImages = images.map((image) => ({
  ...image,
  isTall: TALL_KEYS.has(image.key),
}));
---

<section class="bg-base-100">
  <div class="section-shell">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">{t.gallery?.eyrow || t.gallery?.heading}</p>
        <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">{t.gallery?.heading}</h2>
      </div>
      <a class="btn btn-secondary" href={info.instagramUrl} target="_blank" rel="noreferrer">{t.cta?.instagram}</a>
    </div>

    {variant === 'preview' ? (
      <div class="mosaic mt-8">
        {tieredImages.map((image, i) => (
          <figure class={`mosaic-item mosaic-item--${image.tier} ${image.slotClass} overflow-hidden rounded-lg bg-base-200`}>
            <Image
              class="h-full w-full object-cover transition duration-500 hover:scale-105"
              src={image.src}
              alt={image.alt}
              widths={
                image.tier === 'hero'
                  ? [500, 800, 1100, 1600]
                  : image.tier === 'featured'
                    ? [300, 500, 700]
                    : [200, 350, 500]
              }
              sizes={
                image.tier === 'hero'
                  ? "(max-width: 768px) 100vw, 50vw"
                  : image.tier === 'featured'
                    ? "(max-width: 768px) 50vw, 25vw"
                    : "16vw"
              }
              loading={i === 0 ? 'eager' : 'lazy'}
              format="webp"
              quality={80}
            />
          </figure>
        ))}
      </div>
    ) : (
      <div class="photo-grid mt-8">
        {gridImages.map((image) => (
          <figure class={`photo-grid-item ${image.isTall ? 'photo-grid-item--tall' : ''} overflow-hidden rounded-lg bg-base-200`}>
            <Image
              class="h-full w-full object-cover transition duration-500 hover:scale-105"
              src={image.src}
              alt={image.alt}
              widths={[400, 700, 1100, 1600]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
              loading="lazy"
              format="webp"
              quality={80}
            />
          </figure>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .mosaic {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .mosaic-item--hero {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
    aspect-ratio: 1 / 1;
  }
  .mosaic-item--featured {
    aspect-ratio: 1 / 1;
  }
  .mosaic-slot-1 { grid-column: 3 / 4; grid-row: 1 / 2; }
  .mosaic-slot-2 { grid-column: 4 / 5; grid-row: 1 / 2; }
  .mosaic-slot-3 { grid-column: 3 / 4; grid-row: 2 / 3; }
  .mosaic-slot-4 { grid-column: 4 / 5; grid-row: 2 / 3; }

  .mosaic-item--minor {
    grid-column: span 1;
    aspect-ratio: 1 / 1;
  }

  @media (min-width: 1024px) {
    .mosaic { grid-template-columns: repeat(6, 1fr); }
    .mosaic-item--hero { grid-column: 1 / 3; grid-row: 1 / 3; }
    .mosaic-slot-1 { grid-column: 3 / 4; grid-row: 1 / 2; }
    .mosaic-slot-2 { grid-column: 4 / 5; grid-row: 1 / 2; }
    .mosaic-slot-3 { grid-column: 3 / 4; grid-row: 2 / 3; }
    .mosaic-slot-4 { grid-column: 4 / 5; grid-row: 2 / 3; }
    .mosaic-item--minor { grid-column: span 1; }
  }

  @media (max-width: 1023px) {
    .mosaic-item--minor { display: none; }
  }

  @media (max-width: 640px) {
    .mosaic { grid-template-columns: repeat(2, 1fr); }
    .mosaic-item--hero {
      grid-column: 1 / 3;
      grid-row: auto;
      aspect-ratio: 16 / 10;
    }
    .mosaic-item--featured {
      grid-column: span 1 !important;
      grid-row: auto !important;
      aspect-ratio: 1 / 1;
    }
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-flow: dense;
    grid-auto-rows: 11rem;
    gap: 0.75rem;
  }
  .photo-grid-item { grid-row: span 1; }
  .photo-grid-item--tall { grid-row: span 2; }

  @media (min-width: 640px) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 13rem;
    }
  }
  @media (min-width: 1024px) {
    .photo-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 14rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .mosaic-item img, .photo-grid-item img { transition: none; }
  }
</style>
