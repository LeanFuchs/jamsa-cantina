---
import { siteInfo as info } from '../lib/content';
import logo from '../assets/logo.png'; 
import { Image } from 'astro:assets';
import whatsappUrl from '../utils/get-whatsapp-url'

const { t, currentLang = 'es' } = Astro.props;

const routes = {
  es: { home: '/', about: '/sobre-nosotros', gallery: '/galeria', contact: '/contacto' },
  en: { home: '/en', about: '/en/about', gallery: '/en/gallery', contact: '/en/contact' }
};

const currentRoutes = routes[currentLang as keyof typeof routes];
const languageLabel = currentLang === 'es' ? 'Español' : 'English';

const links = [
  { href: currentRoutes.home, label: t.nav.home },
  { href: currentRoutes.about, label: t.nav.about },
  { href: currentRoutes.gallery, label: t.nav.gallery },
  { href: currentRoutes.contact, label: t.nav.contact }
];
---

<header class="sticky top-0 z-50 border-b border-base-200 bg-base-100/80 backdrop-blur-md">
  <nav class="navbar mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 h-16" aria-label="Primary navigation">
    <div class="navbar-start gap-1">
      <div class="dropdown lg:hidden">
        <button type="button" class="btn btn-ghost btn-circle" aria-label="Open navigation menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <ul class="menu menu-sm dropdown-content z-[100] mt-3 w-56 rounded-xl bg-base-100 p-2 shadow-xl border border-base-200 nav-links-mobile">
          {links.map((link) => (
            <li><a href={link.href} class="py-2.5 rounded-lg font-medium transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <a href={currentRoutes.home} class="flex items-center gap-2.5 group shrink-0">
        <Image src={logo} alt={t.business.name} class="h-12 w-auto object-contain transition-transform group-hover:scale-105" loading="eager" />
        <span class="hidden min-[420px]:block text-lg font-medium tracking-tight text-base-content">
          {t.business.name}
        </span>
      </a>
    </div>

    <div class="navbar-center hidden lg:flex">
      <ul class="flex items-center gap-1 nav-links-desktop">
        {links.map((link) => (
          <li>
            <a href={link.href} class="font-medium px-4 py-2 rounded-lg text-base-content/80 hover:text-base-content hover:bg-base-200/60 transition-all">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

  <div class="navbar-end gap-2">
      <a
        href={info.instagramUrl}
        target="_blank"
        rel="noreferrer"
        class="btn btn-ghost btn-circle btn-sm"
        aria-label="Seguinos en Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-instagram h-5 w-5" viewBox="0 0 16 16">
          <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
        </svg>
      </a>

      <div class="dropdown dropdown-end">
        <button
          type="button"
          class="btn btn-ghost btn-sm text-xs font-bold uppercase tracking-widest"
          aria-label={`Change language. Current language: ${languageLabel}`}
        >
          {currentLang}
        </button>
        <ul class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-20" aria-label="Language options">
          <li><a href="/" aria-label="Ver sitio en español" lang="es">ES</a></li>
          <li><a href="/en" aria-label="View site in English" lang="en">EN</a></li>
        </ul>
      </div>

      {info.menuUrl && (
        <a class="btn btn-ghost btn-sm sm:btn-md font-medium hidden sm:inline-flex" href={info.menuUrl} target="_blank" rel="noreferrer">{t.cta.menu}</a>
      )}

      <a class="btn btn-primary btn-sm sm:btn-md font-semibold shadow-sm" href={whatsappUrl} target="_blank" rel="noreferrer">
        {t.footer.reservation}
      </a>
    </div>
  </nav>
</header>
