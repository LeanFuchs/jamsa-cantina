---
import Hero from './Hero.astro';
import LocationCard from './LocationCard.astro';
import Gallery from './Gallery.astro';
import Reviews from './Reviews.astro';
import { interpolate } from '../lib/content';

const { t } = Astro.props;
---

<Hero t={t} />
<LocationCard t={t} />

<Gallery variant="preview" limit={15} t={t} />
<Reviews t={t} />

<section class="relative bg-[#fcf8f2]">
  <div class="arabic-pattern is-faded-y absolute inset-0 pointer-events-none opacity-[0.05]"></div>
  
  <div class="section-shell grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <p class="eyebrow">{t.home.aboutEyebrow}</p>
      <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">
        {interpolate(t.home.aboutHeading)}
      </h2>
    </div>
    <div class="space-y-5 text-lg leading-8">
      {t.home.aboutParagraphs.map((paragraph) => (
        <p>{interpolate(paragraph)}</p>
      ))}
    </div>
  </div>
</section>
