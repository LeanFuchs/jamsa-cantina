---
const { t } = Astro.props;
---

<section class="bg-base-200">
  <div class="section-shell">
    <p class="eyebrow !text-primary">{t.reviews.eyebrow}</p>
    <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">{t.reviews.heading}</h2>
    
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {t.reviews.items.map((review) => (
        <div class="relative flex flex-col justify-between rounded-xl border border-base-300 bg-base-100 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
          {/* Google G Logo in top right corner */}
          <div class="absolute top-6 right-6 text-neutral/20">
            <svg class="h-5 w-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05" />
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335" />
            </svg>
          </div>

          <div>
            {/* Header: Avatar and User Details */}
            <div class="flex items-center gap-3">
              <div class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-white font-semibold text-lg ${review.avatarBg}`}>
                {review.avatarText}
              </div>
              <div class="pr-6">
                <p class="text-sm font-bold text-neutral leading-tight">{review.author}</p>
                <p class="text-[11px] text-base-content/60 mt-0.5">Local Guide</p>
              </div>
            </div>

            {/* Stars */}
            <div class="mt-3.5 flex items-center gap-0.5">
              {[...Array(review.rating)].map(() => (
                <svg class="h-3.5 w-3.5 text-yellow-400 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            {/* Review text */}
            <p class="mt-3 text-[13.5px] leading-relaxed text-base-content/85 italic">
              "{review.quote}"
            </p>
          </div>

          <div class="mt-4 flex items-center gap-1.5 border-t border-base-200 pt-3 text-[11px] text-base-content/50 font-medium">
            <svg class="h-3 w-3 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
            </svg>
            Reseña verificada en Google Maps
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
