---
import { t } from '../lib/content';
---

<section class="bg-base-200">
  <div class="section-shell">
    <p class="eyebrow">{t.reviews.eyebrow}</p>
    <h2 class="mt-3 font-serif text-4xl font-bold text-neutral">{t.reviews.heading}</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {t.reviews.items.map((review) => (
        <figure class="card rounded-lg border border-base-300 bg-base-100 shadow-sm">
          <div class="card-body">
            <blockquote>
              <p class="leading-7">"{review.quote}"</p>
            </blockquote>
            <figcaption class="text-sm font-semibold text-secondary">{review.source}</figcaption>
          </div>
        </figure>
      ))}
    </div>
  </div>
</section>
